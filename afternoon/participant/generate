#!/usr/bin/env python3
import argparse
import hashlib
import re
import shutil
import sys
from pathlib import Path

import markdown
import weasyprint
import yaml
from jinja2 import Environment, FileSystemLoader, StrictUndefined

SCRIPT_DIR = Path(__file__).parent


def highlight_code_blocks(html):
    def repl(m):
        return re.sub(
            r'&gt;&gt;([^\n]*)',
            r'<span style="color: green; font-weight: bold;">\1</span>',
            m.group(0),
        )
    return re.sub(r'<pre><code>.*?</code></pre>', repl, html, flags=re.DOTALL)

VARS_FILE = SCRIPT_DIR / "vars.yaml"


def main():
    parser = argparse.ArgumentParser(description="Generate containerlab participant files from Jinja2 templates")
    parser.add_argument("-id", type=int, required=True, metavar="N", help="Participant ID (1-100)")
    parser.add_argument("-indir", metavar="DIR", default=str(SCRIPT_DIR / "files-start"), help="Template input directory (default: ./files-start/)")
    parser.add_argument("-outdir", metavar="DIR", default=None, help="Output directory (default: stdout)")
    args = parser.parse_args()

    if not 1 <= args.id <= 100:
        print(f"error: -id must be between 1 and 100, got {args.id}", file=sys.stderr)
        sys.exit(1)

    files_dir = Path(args.indir)

    with VARS_FILE.open() as f:
        context = yaml.safe_load(f) or {}
    context["id"] = args.id
    context["pin"] = f"{int(hashlib.md5(str(args.id).encode()).hexdigest(), 16) % 10000:04d}"

    env = Environment(
        loader=FileSystemLoader(str(files_dir)),
        keep_trailing_newline=True,
        undefined=StrictUndefined,
    )

    all_files = sorted(files_dir.rglob("*"))
    all_files = [f for f in all_files if f.is_file()]
    if not all_files:
        print(f"error: no files found under {files_dir}", file=sys.stderr)
        sys.exit(1)

    md_files = []

    for src_path in all_files:
        rel = src_path.relative_to(files_dir)
        is_template = src_path.suffix == ".j2"
        out_name = rel.with_suffix("") if is_template else rel

        if args.outdir is None:
            if is_template:
                rendered = env.get_template(str(rel)).render(context)
                print(f"### {out_name} ###")
                print(rendered)
            else:
                print(f"### {out_name} (copy) ###")
        else:
            out_path = Path(args.outdir) / out_name
            out_path.parent.mkdir(parents=True, exist_ok=True)
            if out_path.exists():
                print(f"error: {out_path} already exists, refusing to overwrite", file=sys.stderr)
                sys.exit(1)
            if is_template:
                rendered = env.get_template(str(rel)).render(context)
                out_path.write_text(rendered)
                if out_path.suffix == ".md":
                    md_files.append((out_path, rendered))
            else:
                shutil.copy2(src_path, out_path)

    for out_path, rendered in md_files:
        html = markdown.markdown(rendered, extensions=["tables", "fenced_code"])
        html = highlight_code_blocks(html)
        css = weasyprint.CSS(string="@page { margin: 1cm; } body { font-size: 11px; } :not(pre) > code { color: darkgreen; } pre code { color: darkred; }")
        docs_dir = Path(args.outdir) / "docs"
        docs_dir.mkdir(parents=True, exist_ok=True)
        pdf_path = docs_dir / f"HOWTO-p{args.id}.pdf"
        weasyprint.HTML(string=html, base_url=str(docs_dir)).write_pdf(pdf_path, stylesheets=[css])


if __name__ == "__main__":
    main()
